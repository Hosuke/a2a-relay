{
  "agents": {
    "operator@example": {
      "enabled": true,
      "allowed_from": ["worker@example"],
      "allowed_types": ["request"],
      "require_needs_reply": true,
      "default_action": "auto-reply",
      "max_body_chars": 20000,
      "stdout_max_chars": 12000
    }
  },
  "actions": {
    "auto-reply": {
      "argv": ["python", "-m", "local_agent_reply"],
      "cwd": "/srv/operator-agent",
      "timeout_seconds": 120
    }
  }
}
